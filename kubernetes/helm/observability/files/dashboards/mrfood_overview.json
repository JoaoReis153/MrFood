  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(traces_spanmetrics_calls_total, service)",
        "definition": "label_values(traces_spanmetrics_calls_total, service)",
        "regex": "/^(?!keycloak$).+$/",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  }
}