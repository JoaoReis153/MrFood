        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service)(rate(traces_spanmetrics_calls_total{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
