{
  "realm": "mrfood",
  "enabled": true,
  "displayName": "MrFood",
  "loginWithEmailAllowed": true,
  "registrationEmailAsUsername": false,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 36000,
  "requiredActions": [
    { "alias": "VERIFY_EMAIL",         "name": "Verify Email",          "providerId": "VERIFY_EMAIL",         "enabled": true, "defaultAction": false, "priority": 50,  "config": {} },
    { "alias": "UPDATE_PROFILE",       "name": "Update Profile",        "providerId": "UPDATE_PROFILE",       "enabled": true, "defaultAction": false, "priority": 40,  "config": {} },
    { "alias": "CONFIGURE_TOTP",       "name": "Configure OTP",         "providerId": "CONFIGURE_TOTP",       "enabled": true, "defaultAction": false, "priority": 10,  "config": {} },
    { "alias": "UPDATE_PASSWORD",      "name": "Update Password",       "providerId": "UPDATE_PASSWORD",      "enabled": true, "defaultAction": false, "priority": 30,  "config": {} },
    { "alias": "TERMS_AND_CONDITIONS", "name": "Terms and Conditions",  "providerId": "TERMS_AND_CONDITIONS", "enabled": false,"defaultAction": false, "priority": 20,  "config": {} }
  ],
  "roles": {
    "realm": [
      { "name": "user",  "description": "Regular app user"  },
      { "name": "admin", "description": "Admin user" }
    ]
  },
  "clients": [
    {
      "clientId": "mrfood-auth",
      "name": "MrFood Auth Service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "mrfood-auth-client-secret",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "attributes": {
        "access.token.signed.response.alg": "RS256"
      },
      "protocolMappers": [
        {
          "name": "user_id mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "false",
            "user.attribute": "int_id",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "user_id",
            "jsonType.label": "String"
          }
        },
        {
          "name": "username mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "false",
            "user.attribute": "username",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "username",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "components": {
    "org.keycloak.keys.KeyProvider": [
      {
        "name": "mrfood-rsa-key",
        "providerId": "rsa",
        "subComponents": {},
        "config": {
          "priority": ["200"],
          "enabled": ["true"],
          "active":  ["true"],
          "algorithm": ["RS256"],
          "privateKey": [
            ""
          ]
        }
      }
    ]
  }
}
