# ===================================================================
# config.env — Non-sensitive configuration (safe to commit to git)
#
# Contains: service ports, DB names/users, cross-service addresses,
# shared app tunables, and infrastructure config.
# Secrets (passwords, tokens, SMTP creds) go in .env files.
# ===================================================================

# --- Logging ---
APP_LOG_LEVEL=debug

# --- Database connection pool (shared defaults) ---
DB_MIN_CONNS=4
DB_MAX_CONNS=20
DB_MAX_CONN_LIFETIME=15m
DB_HEALTH_CHECK_PERIOD=1m

# --- Service ports ---
AUTH_SERVER_PORT=50051
RESTAURANT_SERVER_PORT=50052
BOOKING_SERVER_PORT=50053
SPONSOR_SERVER_PORT=50054
REVIEW_SERVER_PORT=50055
SEARCH_SERVER_PORT=50056
PAYMENT_SERVER_PORT=50057
NOTIFICATION_SERVER_PORT=50058

# --- Auth DB / Redis ---
AUTH_POSTGRES_DB=mrfood_auth
AUTH_POSTGRES_USER=mrfood_auth_user
AUTH_REDIS_DB=0

# --- Restaurant DB ---
RESTAURANT_POSTGRES_DB=mrfood_restaurant
RESTAURANT_POSTGRES_USER=restaurant

# --- Booking DB ---
BOOKING_POSTGRES_DB=mrfood_booking
BOOKING_POSTGRES_USER=booking

# --- Review DB ---
REVIEW_POSTGRES_DB=mrfood_review
REVIEW_POSTGRES_USER=review

# --- Sponsor DB ---
SPONSOR_POSTGRES_DB=mrfood_sponsor
SPONSOR_POSTGRES_USER=sponsor

# --- Payment DB ---
PAYMENT_POSTGRES_DB=mrfood_payment
PAYMENT_POSTGRES_USER=payment

# --- Cross-service gRPC addresses (container DNS names + internal ports) ---
AUTH_TO_NOTIFICATION_GRPC_ADDR=notification:50058
RESTAURANT_GRPC_ADDR=restaurant:50052
REVIEW_GRPC_ADDR=review:50055
REVIEW_TO_RESTAURANT_GRPC_ADDR=restaurant:50052
PAYMENT_GRPC_ADDR=payment:50057
NOTIFICATION_GRPC_ADDR=notification:50058

# --- Notification / SMTP (non-secret) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Search / Elasticsearch ---
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=restaurants

# --- CDC / Kafka ---
CDC_KAFKA_PORT=9092
CDC_CONNECT_PORT=8083
CDC_ELASTIC_PORT=9200
CDC_RESTAURANT_DB_PORT=5437
CDC_RESTAURANT_DB=mrfood_restaurant
CDC_RESTAURANT_USER=restaurant

# --- Kong Gateway ---
GW_IMAGE=kong/kong-gateway:3.13.0.2
