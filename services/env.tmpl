# ============================================================
# MrFood — all service secrets in one place
# Copy to services/.env and fill in values before running.
# This file is committed; services/.env is git-ignored.
# ============================================================

# ── Shared ───────────────────────────────────────────────────
# Used by Kong (JWT verification) and auth service (JWT signing)
APP_JWT_ACCESS_TOKEN_SECRET=

# ── Auth ─────────────────────────────────────────────────────
AUTH_POSTGRES_PASSWORD=
AUTH_REDIS_PASS=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_PASS=

# ── Booking ──────────────────────────────────────────────────
BOOKING_POSTGRES_PASSWORD=

# ── Notification ─────────────────────────────────────────────
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Payment ──────────────────────────────────────────────────
PAYMENT_POSTGRES_PASSWORD=

# ── Restaurant ───────────────────────────────────────────────
RESTAURANT_POSTGRES_PASSWORD=

# ── Review ───────────────────────────────────────────────────
REVIEW_POSTGRES_PASSWORD=

# ── Search / Elasticsearch ───────────────────────────────────
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ── Sponsor ──────────────────────────────────────────────────
SPONSOR_POSTGRES_PASSWORD=

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=