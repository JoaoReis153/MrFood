# ===================================================================
# env.tmpl — Template for all secret .env files
#
# HOW TO USE:
#   Non-sensitive config (ports, DB names, users, addresses) lives
#   in config.env (committed to git).
#
#   This template documents which secrets go in each .env file.
#   Copy the relevant section, fill in real values, and save it
#   in the correct location before running docker compose.
#
# FILE LOCATIONS (all git-ignored):
#   services/.env              → shared JWT secrets
#   services/auth/.env         → auth DB password, Redis pass
#   services/restaurant/.env   → restaurant DB password
#   services/booking/.env      → booking DB password
#   services/review/.env       → review DB password
#   services/sponsor/.env      → sponsor DB password
#   services/payment/.env      → payment DB password
#   services/notification/.env → SMTP credentials
#   services/search/.env       → Elasticsearch credentials
#   services/cdc/.env          → CDC source DB password
# ===================================================================


# ===================================================================
# services/.env  (shared secrets)
# ===================================================================

AUTH_JWT_ACCESS_TOKEN_SECRET=
AUTH_JWT_REFRESH_TOKEN_SECRET=


# ===================================================================
# services/auth/.env
# ===================================================================

# Used by the auth app
AUTH_POSTGRES_PASSWORD=
AUTH_REDIS_PASS=
# Used by the postgres image (same value as AUTH_POSTGRES_PASSWORD)
POSTGRES_PASSWORD=


# ===================================================================
# services/restaurant/.env
# ===================================================================

RESTAURANT_POSTGRES_PASSWORD=
POSTGRES_PASSWORD=


# ===================================================================
# services/booking/.env
# ===================================================================

BOOKING_POSTGRES_PASSWORD=
DB_PASS=               # read by the booking app
POSTGRES_PASSWORD=     # read by the postgres image


# ===================================================================
# services/review/.env
# ===================================================================

REVIEW_POSTGRES_PASSWORD=
POSTGRES_PASSWORD=


# ===================================================================
# services/sponsor/.env
# ===================================================================

SPONSOR_POSTGRES_PASSWORD=
DB_PASS=
POSTGRES_PASSWORD=


# ===================================================================
# services/payment/.env
# ===================================================================

PAYMENT_POSTGRES_PASSWORD=
POSTGRES_PASSWORD=


# ===================================================================
# services/notification/.env
# ===================================================================

SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=


# ===================================================================
# services/search/.env
# ===================================================================

ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=


# ===================================================================
# services/cdc/.env
# ===================================================================

CDC_RESTAURANT_PASSWORD=